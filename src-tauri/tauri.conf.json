{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flow-roulette",
  "version": "0.1.0",
  "identifier": "com.zhuke.flow-roulette",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flow Roulette",
        "width": 1000,
        "height": 750,
        "resizable": true
      },
      {
        "label": "timer",
        "title": "Timer",
        "url": "index.html",
        "width": 350,
        "height": 350,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}